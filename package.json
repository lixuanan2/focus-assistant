{
  "name": "focus-assistant",
  "version": "0.2.0",
  "description": "一个轻量、无依赖、以本地存储为主的浏览器专注插件。当前版本已经从基础黑名单扩展到多模式分组拦截，并保留后续继续加严规则的结构空间。",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "node --test tests/core-logic.test.mjs",
    "test:ui": "playwright test",
    "test:ui:headed": "playwright test --headed",
    "test:ui:edge": "PW_BROWSER_CHANNEL=msedge playwright test --headed"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lixuanan2/focus-assistant.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/lixuanan2/focus-assistant/issues"
  },
  "homepage": "https://github.com/lixuanan2/focus-assistant#readme",
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
